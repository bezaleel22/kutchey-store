{
  "name": "my-qwik-basic-starter",
  "description": "Demo App with Routing built-in (recommended)",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "trustedDependencies": [
    "sharp"
  ],
  "trustedDependencies-annotation": "Needed for bun to allow running install scripts",
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build && bun run i18n-translate",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/bun/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "deploy": "echo 'Run \"npm run qwik add\" to install a server adapter'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "i18n-extract": "node_modules/.bin/localize-extract -s \"dist/build/*.js\" -l es -f json -o src/locales/message.de.json",
    "i18n-translate": "node_modules/.bin/localize-translate -s \"*.js\" -t src/locales/message.*.json -o dist/build/{{LOCALE}} -r ./dist/build",
    "lint": "eslint \"src/**/*.ts*\"",
    "prei18n-extract": "vite build",
    "preview": "qwik build preview && vite preview --open",
    "serve": "bun server/entry.bun.js",
    "start": "vite --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@angular/compiler": "^16.2.2",
    "@angular/compiler-cli": "^16.2.2",
    "@builder.io/qwik": "^1.5.7",
    "@builder.io/qwik-city": "^1.5.7",
    "@builder.io/qwik-labs": "github:QwikDev/qwik-labs-build#main",
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/typescript": "^4.0.7",
    "@graphql-codegen/typescript-generic-sdk": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^4.2.1",
    "@types/braintree-web-drop-in": "^1.39.3",
    "@types/bun": "^1.1.5",
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vendure/cli": "^2.2.6",
    "@vendure/ui-devkit": "^2.2.6",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-qwik": "^1.5.7",
    "postcss": "^8.4.31",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.4",
    "qwik-image": "^0.0.13",
    "tailwindcss": "3.3.3",
    "typescript": "5.4.5",
    "undici": "*",
    "vite": "^5.2.10",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "dependencies": {
    "@angular/localize": "^16.2.2",
    "@stripe/stripe-js": "^4.0.0",
    "@tailwindcss/forms": "^0.5.7",
    "@vendure/admin-ui-plugin": "^2.2.6",
    "@vendure/asset-server-plugin": "^2.2.6",
    "@vendure/core": "^2.2.6",
    "@vendure/email-plugin": "^2.2.6",
    "braintree-web-drop-in": "^1.42.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  }
}